{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/peteski22/agent-pragma/spec/council-protocol/schemas/code-review-result.schema.json",
  "title": "Code Review Result",
  "description": "Parsed body of a code review response from a single provider.",
  "type": "object",
  "required": ["provider", "quality_rating", "issues", "praise", "summary"],
  "properties": {
    "provider": {
      "type": "string",
      "description": "Provider name."
    },
    "quality_rating": {
      "type": "string",
      "enum": ["excellent", "good", "fair", "needs-work"],
      "description": "Overall quality rating for the reviewed code."
    },
    "issues": {
      "type": "array",
      "description": "List of issues found during review.",
      "items": {
        "type": "object",
        "required": ["severity", "location", "category", "description", "suggestion"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Issue severity."
          },
          "location": {
            "type": "string",
            "description": "File and line reference (e.g., auth.py:45)."
          },
          "category": {
            "type": "string",
            "enum": ["craftsmanship", "architecture", "correctness", "invariants", "maintainability"],
            "description": "Review focus area."
          },
          "description": {
            "type": "string",
            "description": "What is wrong."
          },
          "suggestion": {
            "type": "string",
            "description": "How to fix it."
          }
        },
        "additionalProperties": false
      }
    },
    "praise": {
      "type": "array",
      "description": "List of things done well.",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "description": "One paragraph overall assessment."
    }
  },
  "additionalProperties": false
}
