{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/peteski22/agent-pragma/spec/council-protocol/schemas/provider-response.schema.json",
  "title": "Provider Response",
  "description": "Raw response wrapper from a single provider. Contains either content (success) or error (failure).",
  "type": "object",
  "required": ["provider", "model", "success"],
  "properties": {
    "provider": {
      "type": "string",
      "description": "Provider name."
    },
    "model": {
      "type": "string",
      "description": "Model identifier used."
    },
    "success": {
      "type": "boolean",
      "description": "Whether the provider returned a valid response."
    },
    "content": {
      "type": "string",
      "description": "Raw response content from the provider. Present when success is true."
    },
    "error": {
      "type": "string",
      "description": "Error message. Present when success is false."
    }
  },
  "if": {
    "properties": { "success": { "const": true } }
  },
  "then": {
    "required": ["content"],
    "not": { "required": ["error"] }
  },
  "else": {
    "required": ["error"],
    "not": { "required": ["content"] }
  },
  "additionalProperties": false
}
